# Credentials are NOT stored in .env files.
# Add these exports to your ~/.zshrc instead:
#
#   export SNOWFLAKE_ACCOUNT="abc12345.ap-southeast-2.aws"
#   export SNOWFLAKE_PASSWORD="your-password"
#   export OPENAI_API_KEY="sk-..."
#
# Then run: source ~/.zshrc
#
# For Streamlit Cloud deployment, add secrets via the dashboard:
#   Settings → Secrets → paste OPENAI_API_KEY = "sk-..."
